# =====================================================================
# AGRO PARALLEL - AGRO NEWS BOT
# cp .env.example .env  →  completar con valores reales
# NUNCA subir el .env al repositorio
# =====================================================================

# ─────────────────────────────────────────────
# 🔍 NEWSAPI  →  https://newsapi.org/register
# Plan gratis: 100 req/día  (alcanza para 3 ejecuciones diarias)
# ─────────────────────────────────────────────
NEWSAPI_KEY=

# ─────────────────────────────────────────────
# 🤖 ANTHROPIC CLAUDE  →  https://console.anthropic.com/settings/keys
# Costo estimado: ~$10-25/mes (3 ejecuciones diarias)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# 📘 FACEBOOK  →  https://developers.facebook.com/
# Permisos: pages_manage_posts, pages_read_engagement
# Token vence cada 60 días — renovar con:
#   curl "https://graph.facebook.com/oauth/access_token
#     ?grant_type=fb_exchange_token&client_id={APP_ID}
#     &client_secret={APP_SECRET}&fb_exchange_token={SHORT_TOKEN}"
# ─────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ─────────────────────────────────────────────
# 📸 INSTAGRAM  →  Graph API Explorer
# Requisito: cuenta Business/Creator vinculada a Página de FB
# Obtener INSTAGRAM_ACCOUNT_ID:
#   GET /{page_id}?fields=instagram_business_account
# Permisos: instagram_basic, instagram_content_publish
# ─────────────────────────────────────────────
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_PAGE_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# 🌐 WORDPRESS  →  www.agroparallel.com
# App Password: Usuarios > Tu perfil > Contraseñas de aplicación
# ─────────────────────────────────────────────
WP_API_URL=https://www.agroparallel.com/wp-json/wp/v2
WP_USERNAME=
WP_APP_PASSWORD=
WP_DEFAULT_CATEGORY_ID=1

# ─────────────────────────────────────────────
# 🖼️  IMÁGENES - URL pública para Instagram/Facebook
# Las imágenes generadas deben ser accesibles desde internet
# ─────────────────────────────────────────────
IMAGES_BASE_URL=https://www.agroparallel.com/wp-content/uploads/carruseles
IMAGES_UPLOAD_PATH=./data/carousels

# ─────────────────────────────────────────────
# ⚙️  CONFIG GENERAL
# ─────────────────────────────────────────────
NODE_ENV=production
TIMEZONE=America/Argentina/Buenos_Aires
CAROUSEL_OUTPUT_DIR=./data/carousels
LOG_FILE=./logs/bot.log

# ─────────────────────────────────────────────
# 🌐 SERVIDOR WEB EXPRESS
# ─────────────────────────────────────────────
WEB_PORT=3000

# ─────────────────────────────────────────────
# 🚦 PUBLISHERS — Activar/desactivar por plataforma
# true = publica | false = omite
# ─────────────────────────────────────────────
PUBLISH_COUCHDB=true
PUBLISH_WEB=true
PUBLISH_FACEBOOK=false
PUBLISH_INSTAGRAM=false
