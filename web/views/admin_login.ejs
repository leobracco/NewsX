<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login · Agro Parallel Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&display=swap" rel="stylesheet">
  <% if (RECAPTCHA_SITE_KEY) { %>
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <% } %>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Barlow Condensed', Arial Narrow, sans-serif;
      background: #12141E;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* Dot pattern background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(109,194,49,.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    /* Green accent lines */
    body::after {
      content: '';
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: #6DC231;
    }

    .login-container {
      width: 100%;
      max-width: 420px;
      padding: 0 20px;
      position: relative;
      z-index: 1;
    }

    .login-card {
      background: #1A1C26;
      border: 1px solid rgba(255,255,255,.06);
      border-radius: 16px;
      padding: 40px 36px;
      box-shadow: 0 20px 60px rgba(0,0,0,.5);
      position: relative;
      overflow: hidden;
    }

    /* Green left bar */
    .login-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      background: #6DC231;
    }

    .login-brand {
      text-align: center;
      margin-bottom: 32px;
    }

    .login-brand-icon {
      width: 60px;
      height: 60px;
      border-radius: 14px;
      background: #3D4257;
      border: 2px solid #6DC231;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 1.4rem;
      font-weight: 900;
      color: #6DC231;
      letter-spacing: 1px;
    }

    .login-brand h1 {
      font-size: 1.6rem;
      font-weight: 900;
      letter-spacing: 4px;
    }
    .login-brand h1 span { color: #6DC231; }

    .login-brand p {
      font-size: .78rem;
      color: #A0A8C0;
      letter-spacing: 2px;
      margin-top: 4px;
      text-transform: uppercase;
    }

    /* Error messages */
    .login-error {
      background: rgba(231,76,60,.1);
      border: 1px solid rgba(231,76,60,.25);
      color: #E74C3C;
      padding: 10px 16px;
      border-radius: 8px;
      font-size: .82rem;
      font-weight: 600;
      margin-bottom: 20px;
      text-align: center;
    }

    .form-group {
      margin-bottom: 18px;
    }

    .form-label {
      display: block;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #A0A8C0;
      margin-bottom: 8px;
    }

    .form-input {
      width: 100%;
      background: #12141E;
      border: 1px solid rgba(255,255,255,.08);
      color: #fff;
      padding: 12px 16px;
      border-radius: 8px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .95rem;
      font-weight: 600;
      letter-spacing: .5px;
      outline: none;
      transition: border-color .2s;
    }
    .form-input:focus {
      border-color: #6DC231;
    }
    .form-input::placeholder {
      color: rgba(160,168,192,.4);
      font-weight: 400;
    }

    .recaptcha-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 20px;
    }

    .login-btn {
      width: 100%;
      padding: 14px;
      background: #6DC231;
      color: #1A1C26;
      border: none;
      border-radius: 8px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 900;
      letter-spacing: 2px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .2s;
    }
    .login-btn:hover { background: #82dc3a; }
    .login-btn:active { transform: scale(.98); }

    .login-footer {
      text-align: center;
      margin-top: 24px;
      font-size: .75rem;
      color: rgba(160,168,192,.35);
      letter-spacing: .5px;
    }
    .login-footer a {
      color: #6DC231;
      text-decoration: none;
    }
    .login-footer a:hover { text-decoration: underline; }

    /* Background decorative elements */
    .bg-circle {
      position: fixed;
      border-radius: 50%;
      border: 1px solid rgba(109,194,49,.06);
      pointer-events: none;
    }
    .bg-circle-1 { width: 400px; height: 400px; top: -100px; right: -100px; }
    .bg-circle-2 { width: 300px; height: 300px; bottom: -80px; left: -80px; }
    .bg-circle-3 { width: 200px; height: 200px; top: 50%; left: 10%; }
  </style>
</head>
<body>

<div class="bg-circle bg-circle-1"></div>
<div class="bg-circle bg-circle-2"></div>
<div class="bg-circle bg-circle-3"></div>

<div class="login-container">
  <div class="login-card">

    <div class="login-brand">
      <div class="login-brand-icon">AP</div>
      <h1>AGRO <span>PARALLEL</span></h1>
      <p>Panel de Administración</p>
    </div>

    <% if (error === 'credentials') { %>
      <div class="login-error">⚠️ Usuario o contraseña incorrectos</div>
    <% } %>
    <% if (error === 'captcha') { %>
      <div class="login-error">⚠️ Verificación reCAPTCHA fallida, intentá de nuevo</div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label class="form-label">Usuario</label>
        <input type="text" name="username" class="form-input"
               placeholder="Ingresá tu usuario" required autofocus autocomplete="username">
      </div>

      <div class="form-group">
        <label class="form-label">Contraseña</label>
        <input type="password" name="password" class="form-input"
               placeholder="Ingresá tu contraseña" required autocomplete="current-password">
      </div>

      <% if (RECAPTCHA_SITE_KEY) { %>
      <div class="recaptcha-wrap">
        <div class="g-recaptcha" data-sitekey="<%= RECAPTCHA_SITE_KEY %>" data-theme="dark"></div>
      </div>
      <% } %>

      <button type="submit" class="login-btn">🔒 Ingresar</button>
    </form>

    <div class="login-footer">
      <a href="/">← Volver al blog</a>
    </div>

  </div>
</div>

</body>
</html>
